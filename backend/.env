# Server
PORT=5000
HOST=0.0.0.0
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/maktab_ai

# Agar MongoDB o'rnatilmagan bo'lsa, true qo'ying — vaqtinchalik in-memory DB ishlatiladi
# (Faqat dev uchun! Server qayta ishga tushganda ma'lumotlar yo'qoladi.)
USE_MEMORY_DB=true

# JWT
JWT_SECRET=change_me_to_a_long_random_string_in_production_please_seriously
JWT_EXPIRE=7d

# CORS — vergul bilan ajratilgan ro'yxat, yoki * (faqat development)
CORS_ORIGIN=*
